<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>3x3 Card</title>

    <style>
      .row {
        display: flex;
        margin-bottom: 15px;
      }

      .card {
        width: 200px;
        border: 1px solid #ccc;
        border-radius: 8px;
        padding: 10px;
        margin-right: 10px;
        text-align: center;
      }

      .card img {
        width: 100%;
      }
    </style>
  </head>

  <body>
    <div id="container"></div>

    <script>
      var container = document.getElementById("container");
      var sayac = 1;

      for (var i = 1; i <= 3; i++) {
        var row = document.createElement("div");
        row.className = "row";

        for (var j = 1; j <= 3; j++) {
          var card = document.createElement("div");
          card.className = "card";

          var resim = document.createElement("img");
          resim.src = "images/" + sayac + ".jpg";

          var baslik = document.createElement("h3");
          baslik.innerHTML = "Card " + sayac;

          card.appendChild(resim);
          card.appendChild(baslik);

          row.appendChild(card);

          sayac++;
        }

        container.appendChild(row);
      }
    </script>
  </body>
</html>
